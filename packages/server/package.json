{
  "name": "@playwright-cart/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "hono-rate-limiter": "^0.5.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
